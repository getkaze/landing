---
interface Props {
  activePage?: 'home' | 'keel' | 'helm' | 'mole';
}
const { activePage = 'home' } = Astro.props;
---

<nav>
  <div class="nav-inner">
    <a class="nav-logo" href="/">
      <img src="/logo-dark.png" alt="Kaze" width="40" height="40" class="nav-logo-img" />
      <span class="nav-wordmark">kaze</span>
    </a>

    <ul class="nav-links">
      <li><a href="/keel" class:list={[{ active: activePage === 'keel' }]}>Keel</a></li>
      <li><a href="/helm" class:list={[{ active: activePage === 'helm' }]}>Helm</a></li>
      <li><a href="/mole" class:list={[{ active: activePage === 'mole' }]}>Mole</a></li>
      <li class="nav-socials">
        <a href="https://discord.gg/UpX4pfzf" class="nav-icon" target="_blank" rel="noopener noreferrer" aria-label="Discord">
          <svg width="18" height="18" viewBox="0 0 127.14 96.36" fill="currentColor">
            <path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/>
          </svg>
        </a>
        <a href="https://github.com/getkaze" class="nav-icon" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
      </li>
    </ul>

    <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false">
      <svg class="hamburger-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg class="close-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="nav-mobile">
    <a href="/keel" class:list={[{ active: activePage === 'keel' }]}>Keel</a>
    <a href="/helm" class:list={[{ active: activePage === 'helm' }]}>Helm</a>
    <a href="/mole" class:list={[{ active: activePage === 'mole' }]}>Mole</a>
    <div class="nav-mobile-socials">
      <a href="https://discord.gg/UpX4pfzf" target="_blank" rel="noopener noreferrer" aria-label="Discord">Discord</a>
      <a href="https://github.com/getkaze" target="_blank" rel="noopener noreferrer" aria-label="GitHub">GitHub</a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--z-nav);
    background: rgba(248, 250, 252, 0.6);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: var(--radius-pill);
    width: var(--shell-width);
    max-width: 76rem;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    height: 48px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text);
  }

  .nav-logo-img {
    border-radius: 4px;
  }

  .nav-wordmark {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-text);
  }

  .nav-socials {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-left: var(--space-sm);
  }

  .nav-icon {
    display: flex;
    align-items: center;
    color: var(--color-text-muted) !important;
    transition: color var(--duration-fast) !important;
  }

  .nav-icon:hover {
    color: var(--color-text) !important;
  }

  .nav-hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    padding: var(--space-xs);
  }

  .nav-hamburger .close-icon { display: none; }
  .nav-hamburger[aria-expanded="true"] .hamburger-icon { display: none; }
  .nav-hamburger[aria-expanded="true"] .close-icon { display: block; }

  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: var(--space-lg);
    border-top: 1px solid var(--color-border-light);
    background: var(--color-bg);
  }

  .nav-mobile a {
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-sm) 0;
    transition: color var(--duration-fast);
  }

  .nav-mobile a:hover,
  .nav-mobile a.active {
    color: var(--color-text);
  }

  .nav-mobile-socials {
    display: flex;
    gap: var(--space-lg);
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border-light);
  }

  .nav-mobile-socials a {
    font-size: var(--text-small);
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .nav-inner { padding: 0 var(--space-md); }
    .nav-links { display: none; }
    .nav-hamburger { display: flex; }
    nav.open .nav-mobile { display: flex; }
  }
</style>

<script>
  const hamburger = document.querySelector('.nav-hamburger');
  const nav = document.querySelector('nav');
  hamburger?.addEventListener('click', () => {
    const expanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('open');
  });
</script>
