---
interface Props {
  items: Array<{
    quote: string;
    author: string;
    handle: string;
    photo?: string;
    linkedin?: string;
  }>;
}

const { items } = Astro.props;
---

<div class="testimonials-wrap">
  <section class="testimonials-section">
    <h2 class="testimonials-title">Customer Testimonials</h2>

    <div class="testimonials-viewport" data-testimonials>
      <div class="testimonials-track" data-track>
        {items.map((item, i) => (
          <blockquote class="testimonial-card" data-card={i}>
            <p class="testimonial-quote">&ldquo;{item.quote}&rdquo;</p>
            <footer class="testimonial-footer">
              <div class="testimonial-avatar">
                {item.photo
                  ? <img src={item.photo} alt={item.author} />
                  : <span class="testimonial-avatar-placeholder">{item.author.charAt(0)}</span>
                }
              </div>
              <div class="testimonial-info">
                <span class="testimonial-author">{item.author}</span>
                {item.linkedin && (
                  <a href={item.linkedin} target="_blank" rel="noopener noreferrer" class="testimonial-linkedin">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                    <span>{item.handle}</span>
                  </a>
                )}
              </div>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>

    <div class="testimonials-controls">
      <button class="testimonial-btn" aria-label="Previous" data-prev>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/>
        </svg>
      </button>
      <button class="testimonial-btn testimonial-btn-active" aria-label="Next" data-next>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="M12 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  </section>
</div>

<style>
  .testimonials-wrap {
    width: 100%;
    background: transparent;
  }

  .testimonials-section {
    padding: var(--space-3xl) var(--space-lg);
    max-width: 1120px;
    margin: 0 auto;
    text-align: center;
  }

  .testimonials-title {
    font-size: var(--text-h1);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-2xl);
  }

  .testimonials-viewport {
    overflow: hidden;
    margin: 0 calc(-1 * var(--space-lg));
    padding: var(--space-lg);
  }

  .testimonials-track {
    display: flex;
    gap: var(--space-lg);
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .testimonial-card {
    flex: 0 0 calc(33.333% - var(--space-lg) * 2 / 3);
    background: var(--color-bg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    margin: 0;
    text-align: left;
    opacity: 0.4;
    transform: scale(0.92);
    transition: opacity 0.4s ease, transform 0.4s ease, box-shadow 0.4s ease;
  }

  .testimonial-card.testimonial-focus {
    opacity: 1;
    transform: scale(1);
    box-shadow: var(--shadow-lg, 0 8px 32px rgba(0, 0, 0, 0.08));
  }

  .testimonial-quote {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-xl);
  }

  .testimonial-focus .testimonial-quote {
    color: var(--color-text);
  }

  .testimonial-footer {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .testimonial-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-accent-light);
  }

  .testimonial-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-avatar-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-weight: 600;
    font-size: var(--text-body);
    color: var(--color-accent);
  }

  .testimonial-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testimonial-author {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-text);
  }

  .testimonial-linkedin {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .testimonial-linkedin:hover {
    color: #0a66c2;
  }

  .testimonials-controls {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .testimonial-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .testimonial-btn:hover,
  .testimonial-btn-active {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  @media (max-width: 1024px) {
    .testimonial-card {
      flex: 0 0 calc(50% - var(--space-lg) / 2);
    }
  }

  @media (max-width: 640px) {
    .testimonials-section {
      padding: var(--space-2xl) var(--space-md);
    }

    .testimonial-card {
      flex: 0 0 85%;
    }
  }
</style>

<script>
  const container = document.querySelector('[data-testimonials]');
  const track = document.querySelector('[data-track]') as HTMLElement;
  const cards = document.querySelectorAll('[data-card]');
  const prevBtn = document.querySelector('[data-prev]');
  const nextBtn = document.querySelector('[data-next]');

  if (track && cards.length > 0) {
    let centerIndex = 1; // start with second card in focus
    const total = cards.length;

    function getVisibleCount() {
      if (window.innerWidth <= 640) return 1;
      if (window.innerWidth <= 1024) return 2;
      return 3;
    }

    function update() {
      const visible = getVisibleCount();
      const cardEl = cards[0] as HTMLElement;
      const gap = parseFloat(getComputedStyle(track).gap) || 24;
      const cardWidth = cardEl.offsetWidth + gap;

      // Calculate offset to center the active card
      const viewportWidth = (container as HTMLElement).offsetWidth;
      const offset = centerIndex * cardWidth - (viewportWidth / 2) + (cardEl.offsetWidth / 2);
      track.style.transform = `translateX(${-Math.max(0, offset)}px)`;

      cards.forEach((card, i) => {
        card.classList.toggle('testimonial-focus', i === centerIndex);
      });
    }

    prevBtn?.addEventListener('click', () => {
      centerIndex = Math.max(0, centerIndex - 1);
      update();
    });

    nextBtn?.addEventListener('click', () => {
      centerIndex = Math.min(total - 1, centerIndex + 1);
      update();
    });

    window.addEventListener('resize', update);
    update();
  }
</script>
