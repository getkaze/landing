---
interface Props {
  title?: string;
  code: string;
}
const { title = 'CLI · common commands', code } = Astro.props;
---

<div class="code-block reveal">
  <div class="code-header">
    <div class="code-dots">
      <span></span><span></span><span></span>
    </div>
    <span class="code-title">{title}</span>
  </div>
  <pre class="code-pre" set:html={code} />
</div>

<style>
  .code-block {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 6px;
    overflow: hidden;
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    border-bottom: 1px solid var(--border);
    background: #0e0e0e;
  }

  .code-dots { display: flex; gap: 6px; }

  .code-dots span { width: 10px; height: 10px; border-radius: 50%; }
  .code-dots span:nth-child(1) { background: #ff5f57; }
  .code-dots span:nth-child(2) { background: #febc2e; }
  .code-dots span:nth-child(3) { background: #28c840; }

  .code-title {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted2);
  }

  .code-pre {
    padding: 24px 28px;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.8;
    overflow-x: auto;
    color: #c9c9c9;
  }

  :global(.c-comment) { color: var(--muted2); }
  :global(.c-cmd)     { color: var(--accent); }
  :global(.c-arg)     { color: #a5d6a7; }
  :global(.c-str)     { color: #ffcc80; }
  :global(.c-prompt)  { color: var(--muted2); user-select: none; }
</style>
