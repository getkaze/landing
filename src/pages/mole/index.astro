---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import InstallBlock from '../../components/InstallBlock.astro';
---

<Base
  title="Mole — AI-powered PR reviews + developer growth. Self-hosted."
  description="Self-hosted AI code review and developer growth platform. Powered by Claude. Issue taxonomy, quality scoring, and growth tracking."
>
  <Nav activePage="mole" />

  <!-- TOOL HERO -->
  <div class="tool-hero">
    <div class="tool-hero-badge">
      <span class="dot"></span>
      v0.1 · alpha · MIT
    </div>
    <h1>mole</h1>
    <p class="tool-tagline">AI-powered PR reviews + developer growth.<br/>Self-hosted. One binary or one container.</p>

    <InstallBlock
      command="curl -fsSL https://getkaze.dev/mole/install.sh | sudo bash"
      thenCommand="mole serve"
    />

    <div class="tool-cta">
      <a class="btn-primary" href="https://github.com/getkaze/mole" target="_blank" rel="noopener">View on GitHub →</a>
      <a class="btn-ghost" href="#mole-features">Explore features</a>
      <a class="back-link" href="/">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        All tools
      </a>
    </div>
  </div>

  <!-- STATS -->
  <div class="stat-row">
    <div class="stat-item reveal">
      <div class="stat-value"><em>3</em></div>
      <div class="stat-label">review modes · standard · deep · CLI</div>
    </div>
    <div class="stat-item reveal" style="--reveal-delay: 0.1s">
      <div class="stat-value"><em>6</em></div>
      <div class="stat-label">issue categories · security to style</div>
    </div>
    <div class="stat-item reveal" style="--reveal-delay: 0.2s">
      <div class="stat-value">0–<em>100</em></div>
      <div class="stat-label">quality score per PR</div>
    </div>
  </div>

  <!-- ABOUT -->
  <div class="about-section">
    <div class="about-block reveal">
      <p class="section-label">Vision</p>
      <p class="about-text">
        Mole was born from a simple observation: code review tools stop at the review. They find issues but don't track patterns, measure growth, or help developers improve over time. Mole closes the loop — from PR review to developer growth — in a single self-hosted platform.
      </p>
      <p class="about-text">
        Every PR gets an automated review powered by Claude, with formal issue taxonomy, severity classification, and a quality score. Over time, Mole surfaces trends — which categories each developer struggles with, how scores evolve, and where the team needs training. No other self-hosted tool does this.
      </p>
    </div>
    <div class="about-block reveal" style="--reveal-delay: 0.1s">
      <p class="section-label">Name</p>
      <p class="about-text">
        Named after the <em>mole</em> — the animal that digs deep underground, finding what others miss. Moles work quietly beneath the surface, uncovering things that aren't visible from above.
      </p>
      <p class="about-text">
        The name reflects the tool's purpose: to dig deep into code, surface hidden issues, and elevate the developers who write it. It's not about catching mistakes — it's about building better engineers.
      </p>
    </div>
  </div>

  <!-- FEATURES -->
  <div class="features-section" id="mole-features">
    <div class="features-header">
      <p class="section-label reveal">Features</p>
    </div>
    <div class="features-grid">
      <div class="feature-item reveal">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <h3 class="feature-title">Automated PR Reviews</h3>
        <p class="feature-desc">Every PR gets reviewed on open. Standard reviews use Claude Sonnet, deep reviews use Claude Opus with Mermaid diagrams. Trigger manually with <code>/mole review</code>.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.05s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/>
          </svg>
        </div>
        <h3 class="feature-title">Issue Taxonomy</h3>
        <p class="feature-desc">Every issue is classified into 6 categories — Security, Bugs, Smells, Architecture, Performance, Style — with subcategories. Not just comments, structured data.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.1s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <h3 class="feature-title">Quality Scoring</h3>
        <p class="feature-desc">0–100 quality score per PR based on issue severity and density. Track score trends over weeks and months. Green, yellow, red — instantly visible.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.15s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4-4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3 class="feature-title">Developer Growth Dashboard</h3>
        <p class="feature-desc">Individual issue heatmaps, score trends, streaks, and badges. Team view with anonymous distribution and training suggestions. Role-based access control.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.2s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3 class="feature-title">Security & Architecture Scanner</h3>
        <p class="feature-desc">AST-based security scanning for common vulnerabilities. Architecture validation with layer enforcement rules. Runs before every review.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.25s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><path d="m4.93 4.93 14.14 14.14"/>
          </svg>
        </div>
        <h3 class="feature-title">Bot Personality</h3>
        <p class="feature-desc">Three modes — <code>mole</code> (playful), <code>formal</code> (professional), <code>minimal</code> (terse). Configure per repository in <code>.mole/config.yaml</code>.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.3s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="14" x="2" y="5" rx="2"/><path d="m2 10 20 0"/>
          </svg>
        </div>
        <h3 class="feature-title">CLI Reviews</h3>
        <p class="feature-desc">Review any PR from your terminal with <code>mole review owner/repo#123</code>. Supports <code>--deep</code> for thorough analysis. No browser needed.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.35s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>
          </svg>
        </div>
        <h3 class="feature-title">Context Files</h3>
        <p class="feature-desc">Drop a <code>.mole/</code> directory in your repo with architecture docs, conventions, and decisions. Mole reads them and reviews with full context.</p>
      </div>
    </div>
  </div>

  <!-- STACK -->
  <div class="stack-section reveal">
    <p class="section-label">Stack</p>
    <div class="stack-grid">
      <div class="stack-item">
        <p class="stack-label">Backend</p>
        <p class="stack-value">Go 1.26 · stdlib net/http<br/>Anthropic SDK · go-github v72</p>
      </div>
      <div class="stack-item">
        <p class="stack-label">Dashboard</p>
        <p class="stack-value">Go templates · HTMX 2.0<br/>GitHub OAuth · role-based access</p>
      </div>
      <div class="stack-item">
        <p class="stack-label">Infrastructure</p>
        <p class="stack-value">MySQL 8.0+ · Valkey 7.0+<br/>Prometheus metrics · log/slog</p>
      </div>
      <div class="stack-item">
        <p class="stack-label">Distribution</p>
        <p class="stack-value">go:embed · Docker (multi-arch)<br/>linux/amd64 · linux/arm64 · macOS</p>
      </div>
    </div>
  </div>

  <Footer
    tool="mole"
    extraLinks={[
      { label: 'GitHub', href: 'https://github.com/getkaze/mole' },
      { label: 'All tools', href: '/' },
      { label: 'MIT License', href: 'https://github.com/getkaze/mole/blob/main/LICENSE' },
    ]}
  />
</Base>

<style>
  /* ─── TOOL HERO ─── */
  .tool-hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 24px 80px;
  }

  .tool-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 11px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border2);
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 40px;
    opacity: 0;
    animation: fadeUp .5s .1s forwards;
  }

  .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 6px var(--green);
  }

  .tool-hero h1 {
    font-size: clamp(56px, 10vw, 112px);
    font-weight: 400;
    letter-spacing: -.04em;
    line-height: .95;
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp .5s .2s forwards;
  }

  .tool-tagline {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: clamp(14px, 1.8vw, 18px);
    color: var(--muted);
    max-width: 500px;
    margin: 0 auto 56px;
    opacity: 0;
    animation: fadeUp .5s .3s forwards;
  }

  .tool-cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp .5s .5s forwards;
  }

  /* ─── STATS ─── */
  .stat-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border-radius: 6px;
    overflow: hidden;
    margin: 0 auto 120px;
    max-width: 960px;
    padding: 0;
    width: calc(100% - 48px);
  }

  .stat-item {
    background: var(--surface);
    padding: 36px 32px;
  }

  .stat-value {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 40px;
    font-weight: 400;
    letter-spacing: -.04em;
    color: var(--text);
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-value em {
    font-style: normal;
    color: var(--accent);
  }

  .stat-label {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: .06em;
  }

  /* ─── ABOUT ─── */
  .about-section {
    padding: 0 24px 120px;
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .about-block { padding: 36px 0; }
  .about-block .section-label { margin-bottom: 24px; }

  .about-text {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 16px;
  }

  .about-text:last-child { margin-bottom: 0; }

  .about-text code {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 13px;
    color: var(--accent);
  }

  .about-text em {
    font-style: italic;
    color: var(--text);
  }

  /* ─── FEATURES ─── */
  .features-section {
    padding: 0 24px 120px;
    max-width: 960px;
    margin: 0 auto;
  }

  .features-header { margin-bottom: 0; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .feature-item {
    background: var(--surface);
    padding: 36px 32px;
    transition: background .2s;
  }

  .feature-item:hover { background: #161616; }

  .feature-icon {
    width: 36px; height: 36px;
    border-radius: 6px;
    border: 1px solid var(--border2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: var(--accent);
    transition: border-color .2s;
  }

  .feature-item:hover .feature-icon { border-color: var(--accent); }

  .feature-title {
    font-size: 15px;
    font-weight: 500;
    margin-bottom: 8px;
    letter-spacing: -.01em;
  }

  .feature-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  .feature-desc code {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 12px;
    color: var(--accent);
  }

  /* ─── STACK ─── */
  .stack-section {
    padding: 0 24px 120px;
    max-width: 960px;
    margin: 0 auto;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .stack-item {
    background: var(--surface);
    padding: 28px 32px;
  }

  .stack-label {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 11px;
    color: var(--muted2);
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .stack-value {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 14px;
    color: var(--text);
    line-height: 2;
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .tool-hero {
      padding: 80px 16px 60px;
      min-height: auto;
    }

    .tool-hero h1 { margin-bottom: 24px; }
    .tool-tagline { margin: 0 auto 40px; }
    .tool-cta { gap: 10px; }

    .stat-row {
      grid-template-columns: 1fr;
      width: calc(100% - 32px);
      margin-bottom: 64px;
    }

    .stat-item { padding: 24px 20px; }
    .stat-value { font-size: 32px; }

    .about-section {
      padding: 0 16px 64px;
      grid-template-columns: 1fr;
      gap: 0;
    }

    .about-block { padding: 24px 0; }

    .features-section { padding: 0 16px 64px; }
    .features-grid { grid-template-columns: 1fr; }
    .feature-item { padding: 24px 20px; }

    .stack-section { padding: 0 16px 64px; }
    .stack-grid { grid-template-columns: 1fr; }
    .stack-item { padding: 20px; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = el.style.getPropertyValue('--reveal-delay') || '0s';
          setTimeout(() => {
            el.classList.add('visible');
          }, parseFloat(delay) * 1000);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
