---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Page not found" description="The page you're looking for doesn't exist.">
  <div class="error-page">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/>
      <path d="M9.6 4.6A2 2 0 1 1 11 8H2"/>
      <path d="M12.6 19.4A2 2 0 1 0 14 16H2"/>
    </svg>
    <h1>404</h1>
    <p class="error-message">Page not found.</p>
    <nav class="error-nav">
      <a href="/">Home</a>
      <a href="/keel">Keel</a>
      <a href="/helm">Helm</a>
    </nav>
  </div>
</Base>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px;
  }

  .error-page svg {
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp .5s .1s forwards;
  }

  .error-page h1 {
    font-size: clamp(72px, 15vw, 160px);
    font-weight: 400;
    letter-spacing: -.04em;
    line-height: .9;
    margin-bottom: 16px;
    opacity: 0;
    animation: fadeUp .5s .2s forwards;
  }

  .error-message {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 16px;
    color: var(--muted);
    margin-bottom: 48px;
    opacity: 0;
    animation: fadeUp .5s .3s forwards;
  }

  .error-nav {
    display: flex;
    gap: 16px;
    opacity: 0;
    animation: fadeUp .5s .4s forwards;
  }

  .error-nav a {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    padding: 8px 20px;
    border: 1px solid var(--border2);
    border-radius: 4px;
    transition: color .2s, border-color .2s;
    letter-spacing: .03em;
  }

  .error-nav a:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .error-page { padding: 60px 16px; }
    .error-nav { flex-direction: column; gap: 10px; }
    .error-nav a { text-align: center; }
  }
</style>
