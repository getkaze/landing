---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import InstallBlock from '../../components/InstallBlock.astro';
---

<Base
  title="Keel | One binary. Zero dependencies. Full Docker control."
  description="Self-hosted Docker dashboard for local and remote environments. One binary, zero dependencies."
>
  <Nav activePage="keel" />

  <!-- HERO -->
  <section class="hero">
    <span class="eyebrow">v0.4 · alpha · MIT</span>
    <h1>Keel</h1>
    <p class="lead">One binary. Zero dependencies. Full Docker control.</p>
    <div class="install-wrap">
      <InstallBlock
        command="curl -fsSL https://getkaze.dev/keel/install.sh | sudo bash"
        thenCommand="keel"
      />
    </div>
    <div class="hero-ctas">
      <a href="https://github.com/getkaze/keel" class="btn-primary">View on GitHub</a>
      <a href="/keel/docs" class="btn-secondary">Docs</a>
    </div>
  </section>

  <!-- SCREENSHOT -->
  <section class="screenshot-section">
    <div class="screenshot-frame">
      <img src="/keel/screenshot-dashboard.webp" alt="Keel dashboard" loading="eager" />
    </div>
  </section>

  <!-- WHY -->
  <section>
    <div class="two-col">
      <div>
        <h2>Born from frustration</h2>
        <p>Instead of juggling docker compose files, SSH sessions, and scattered scripts, Keel gives you a single binary that handles everything. Spin up local services, manage remote hosts, all through a clean dashboard or a handful of CLI commands.</p>
      </div>
      <div>
        <h2>The invisible foundation</h2>
        <p>Named after the keel, the structural backbone of a ship. It keeps your development infrastructure steady and on course, just like its namesake.</p>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section>
    <div class="features-row">
      <div class="feature">
        <h3>Real-time dashboard</h3>
        <p>Live container status, log streaming via SSE, interactive terminal via WebSocket with multi-tab support, and inline config editing.</p>
      </div>
      <div class="feature">
        <h3>Full metrics</h3>
        <p>CPU, memory, disk, load average, uptime, and per-container Docker stats. HTTP or command-based health checks with configurable intervals.</p>
      </div>
      <div class="feature">
        <h3>Local and remote</h3>
        <p>Manage local and remote Docker hosts from the same interface. Switch targets with a single command. Dev Mode for hot-reload.</p>
      </div>
      <div class="feature">
        <h3>Simple by design</h3>
        <p>Services as plain JSON, no YAML, no templating. Bootstrap with seeders. One ~10MB binary, zero external dependencies.</p>
      </div>
    </div>
  </section>

  <!-- METRICS SCREENSHOT -->
  <section class="screenshot-section">
    <div class="screenshot-frame">
      <img src="/keel/screenshot-metrics.webp" alt="Keel metrics" loading="lazy" />
    </div>
    <p class="caption">Metrics: real-time host and container monitoring</p>
  </section>

  <!-- CONFIG -->
  <section>
    <h2>Configuration</h2>
    <p class="section-lead">Plain JSON. No magic. No templating engine.</p>
    <div class="code-grid">
      <div class="code-card">
        <span class="code-label">targets.json</span>
        <pre><code>{JSON.stringify({
  "targets": {
    "local": {
      "host": "127.0.0.1",
      "description": "Docker local"
    },
    "staging": {
      "host": "10.0.1.42",
      "ssh_user": "deploy",
      "ssh_key": "~/.ssh/staging.pem",
      "description": "AWS EC2 Staging"
    }
  },
  "default": "local"
}, null, 2)}</code></pre>
      </div>
      <div class="code-card">
        <span class="code-label">service.json</span>
        <pre><code>{JSON.stringify({
  "name": "traefik",
  "group": "infra",
  "image": "traefik:v2.11",
  "network": "keel-net",
  "ports": { "internal": 80, "external": 80 },
  "health_check": {
    "type": "http",
    "url": "http://localhost:8080/api/overview",
    "interval": 10
  }
}, null, 2)}</code></pre>
      </div>
    </div>
  </section>

  <Footer product="keel" />
</Base>

<style>
  .hero {
    text-align: center;
    padding: calc(72px + var(--space-3xl)) var(--space-lg) var(--space-2xl);
    width: var(--shell-narrow);
    margin: 0 auto;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .hero h1 {
    font-size: var(--text-display);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-top: var(--space-lg);
  }

  .lead {
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    margin-top: var(--space-md);
    line-height: var(--leading-relaxed);
    letter-spacing: -0.015em;
  }

  .install-wrap {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    margin-top: var(--space-xl);
  }

  /* Screenshots */
  .screenshot-section {
    padding-top: 0;
  }

  .screenshot-frame {
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06), 0 24px 60px rgba(15, 23, 42, 0.08);
  }

  .screenshot-frame img {
    width: 100%;
    height: auto;
    max-height: 600px;
    object-fit: cover;
    object-position: top left;
    display: block;
  }

  .caption {
    text-align: center;
    font-size: var(--text-small);
    color: var(--color-text-muted);
    margin-top: var(--space-md);
  }

  /* Two col text */
  .two-col {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2xl);
  }

  .two-col h2 {
    font-size: var(--text-h2);
    font-weight: 800;
    margin-bottom: var(--space-sm);
  }

  .two-col p {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  /* Features */
  .features-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .feature h3 {
    font-size: var(--text-body);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .feature p {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  .section-lead {
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2xl);
    letter-spacing: -0.015em;
  }

  /* Code */
  .code-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .code-card {
    background: #0f1117;
    border: 1px solid #1e2028;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .code-label {
    display: block;
    padding: var(--space-sm) var(--space-lg);
    font-family: var(--font-mono);
    font-size: 11px;
    color: #555;
    letter-spacing: 0.06em;
    border-bottom: 1px solid #1e2028;
  }

  .code-card pre {
    margin: 0;
    padding: var(--space-lg);
    overflow-x: auto;
  }

  .code-card code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.6;
    color: #a0a0a0;
    white-space: pre;
    background: none;
    padding: 0;
    border-radius: 0;
  }

  @media (max-width: 768px) {
    .two-col,
    .code-grid {
      grid-template-columns: 1fr;
    }

    .features-row {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero-ctas {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
