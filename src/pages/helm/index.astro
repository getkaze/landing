---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import InstallBlock from '../../components/InstallBlock.astro';
---

<Base
  title="Helm — AI agent orchestration for backend development."
  description="Structured AI agent pipeline for backend projects. One binary, zero dependencies, full session continuity."
>
  <Nav activePage="helm" />

  <!-- TOOL HERO -->
  <div class="tool-hero">
    <div class="tool-hero-badge">
      <span class="dot"></span>
      v0.1 · alpha · MIT
    </div>
    <div class="tool-hero-logo">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64"
           viewBox="0 0 24 24" fill="none"
           stroke="#8b5cf6" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="9"/>
        <circle cx="12" cy="12" r="2"/>
        <line x1="12" y1="3"  x2="12" y2="10"/>
        <line x1="12" y1="14" x2="12" y2="21"/>
        <line x1="3"  y1="12" x2="10" y2="12"/>
        <line x1="14" y1="12" x2="21" y2="12"/>
        <line x1="5.64" y1="5.64" x2="9.17" y2="9.17"/>
        <line x1="14.83" y1="14.83" x2="18.36" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="14.83" y2="9.17"/>
        <line x1="9.17" y1="14.83" x2="5.64" y2="18.36"/>
        <circle cx="12" cy="3" r="1"/>
        <circle cx="12" cy="21" r="1"/>
        <circle cx="3" cy="12" r="1"/>
        <circle cx="21" cy="12" r="1"/>
        <circle cx="5.64" cy="5.64" r="1"/>
        <circle cx="18.36" cy="18.36" r="1"/>
        <circle cx="18.36" cy="5.64" r="1"/>
        <circle cx="5.64" cy="18.36" r="1"/>
      </svg>
    </div>
    <h1>helm</h1>
    <p class="tool-tagline">AI agent orchestration<br/>for backend development.</p>

    <InstallBlock
      command="curl -fsSL https://getkaze.dev/helm/install.sh | bash"
      thenCommand="helm init"
    />

    <div class="tool-cta">
      <a class="btn-primary" href="https://github.com/getkaze/helm" target="_blank" rel="noopener">View on GitHub →</a>
      <a class="btn-ghost" href="/helm/docs">Docs</a>
      <a class="back-link" href="/">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        All tools
      </a>
    </div>
  </div>

  <!-- STATS -->
  <div class="stat-row">
    <div class="stat-item reveal">
      <div class="stat-value"><em>13</em></div>
      <div class="stat-label">agents total</div>
    </div>
    <div class="stat-item reveal" style="--reveal-delay: 0.1s">
      <div class="stat-value"><em>5</em></div>
      <div class="stat-label">pipeline phases</div>
    </div>
    <div class="stat-item reveal" style="--reveal-delay: 0.2s">
      <div class="stat-value"><em>10</em></div>
      <div class="stat-label">governance rules</div>
    </div>
  </div>

  <!-- ABOUT -->
  <div class="about-section">
    <div class="about-block reveal">
      <p class="section-label">Vision</p>
      <p class="about-text">
        Helm was born from the observation that AI-assisted development works best when structured. Instead of free-form prompting, Helm guides your project through a pipeline of specialized agents — from discovery and planning to implementation and deployment — each with clear acceptance criteria and quality gates.
      </p>
      <p class="about-text">
        Helm is a <strong>state manager, not an executor</strong>. Agent logic lives in markdown definitions and runs inside Claude Code. The CLI manages session state, displays progress, and bridges the gap between conversations. Stop, resume, and checkpoint at any point.
      </p>
    </div>
    <div class="about-block reveal" style="--reveal-delay: 0.1s">
      <p class="section-label">Name</p>
      <p class="about-text">
        Named after the <em>helm</em> — the wheel that steers a ship's direction. The helm is what translates the captain's intent into the rudder's movement. Without it, a ship drifts.
      </p>
      <p class="about-text">
        The name reflects the tool's purpose: to steer your development pipeline with structure and intent — keeping every agent on course, every handoff clean, and every decision traceable.
      </p>
    </div>
  </div>

  <!-- FEATURES -->
  <div class="features-section" id="helm-features">
    <div class="features-header">
      <p class="section-label reveal">Features</p>
    </div>
    <div class="features-grid">
      <div class="feature-item reveal">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>
          </svg>
        </div>
        <h3 class="feature-title">Structured Pipeline</h3>
        <p class="feature-desc">Five phases — Discover, Plan, Build, Quality, Deploy — with 13 agents. Each agent has a clear mission, inputs, outputs, and success criteria.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.05s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3 class="feature-title">Specialized Agents</h3>
        <p class="feature-desc">Scout, Research, Architect, Build, Verify, Ship — each agent drives one phase of work. No generic prompting. Every agent knows its mission from the handoff.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.1s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/>
          </svg>
        </div>
        <h3 class="feature-title">Quality Gates</h3>
        <p class="feature-desc">Two QA checkpoints at 95% threshold: Review validates planning traceability, Verify validates implementation. Nothing ships without passing both gates.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.15s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
          </svg>
        </div>
        <h3 class="feature-title">Session Continuity</h3>
        <p class="feature-desc">Checkpoint state with <code>helm save</code>, close Claude Code, and resume later with <code>helm resume</code>. All progress survives across sessions.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.2s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 20h.01"/><path d="M7 20v-4"/><path d="M12 20v-8"/><path d="M17 20V8"/><path d="M22 4v16"/>
          </svg>
        </div>
        <h3 class="feature-title">Execution Profiles</h3>
        <p class="feature-desc">Three modes — Explore (read-only), Guided (confirm before writes), Autonomous (auto-execute when gates pass at 95%). Safety net triggers revert to guided.</p>
      </div>
      <div class="feature-item reveal" style="--reveal-delay: 0.25s">
        <div class="feature-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
          </svg>
        </div>
        <h3 class="feature-title">Full Traceability</h3>
        <p class="feature-desc">Every task traces to a requirement. Every requirement traces to a research problem. Review validates this chain end-to-end before build starts.</p>
      </div>
    </div>
  </div>

  <!-- STACK -->
  <div class="stack-section reveal">
    <p class="section-label">Stack</p>
    <div class="stack-grid">
      <div class="stack-item">
        <p class="stack-label">CLI</p>
        <p class="stack-value">Go 1.26 · spf13/cobra<br/>gopkg.in/yaml.v3 · fatih/color</p>
      </div>
      <div class="stack-item">
        <p class="stack-label">Agent Runtime</p>
        <p class="stack-value">Claude Code · Markdown definitions<br/>YAML session state · Handoff documents</p>
      </div>
      <div class="stack-item">
        <p class="stack-label">Distribution</p>
        <p class="stack-value">Single binary · ldflags version injection<br/>linux/amd64 · linux/arm64 · macOS (amd64 + arm64)</p>
      </div>
      <div class="stack-item">
        <p class="stack-label">Quality</p>
        <p class="stack-value">10 governance rules · 95% QA gates<br/>Given-When-Then acceptance criteria</p>
      </div>
    </div>
  </div>

  <Footer
    tool="helm"
    extraLinks={[
      { label: 'GitHub', href: 'https://github.com/getkaze/helm' },
      { label: 'All tools', href: '/' },
      { label: 'MIT License', href: 'https://github.com/getkaze/helm/blob/main/LICENSE' },
    ]}
  />
</Base>

<style>
  /* ─── TOOL HERO ─── */
  .tool-hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 24px 80px;
  }

  .tool-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 11px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border2);
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 40px;
    opacity: 0;
    animation: fadeUp .5s .1s forwards;
  }

  .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 6px var(--green);
  }

  .tool-hero-logo {
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp .5s .15s forwards;
  }

  .tool-hero h1 {
    font-size: clamp(56px, 10vw, 112px);
    font-weight: 400;
    letter-spacing: -.04em;
    line-height: .95;
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp .5s .2s forwards;
  }

  .tool-tagline {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: clamp(14px, 1.8vw, 18px);
    color: var(--muted);
    max-width: 500px;
    margin: 0 auto 56px;
    opacity: 0;
    animation: fadeUp .5s .3s forwards;
  }

  .tool-cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp .5s .5s forwards;
  }

  /* ─── STATS ─── */
  .stat-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border-radius: 6px;
    overflow: hidden;
    margin: 0 auto 120px;
    max-width: 960px;
    padding: 0;
    width: calc(100% - 48px);
  }

  .stat-item {
    background: var(--surface);
    padding: 36px 32px;
  }

  .stat-value {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 40px;
    font-weight: 400;
    letter-spacing: -.04em;
    color: var(--text);
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-value em {
    font-style: normal;
    color: var(--accent);
  }

  .stat-label {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: .06em;
  }

  /* ─── ABOUT ─── */
  .about-section {
    padding: 0 24px 120px;
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .about-block {
    padding: 36px 0;
  }

  .about-block .section-label {
    margin-bottom: 24px;
  }

  .about-text {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 16px;
  }

  .about-text:last-child {
    margin-bottom: 0;
  }

  .about-text code {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 13px;
    color: var(--accent);
  }

  .about-text em {
    font-style: italic;
    color: var(--text);
  }

  .about-text strong {
    font-weight: 500;
    color: var(--text);
  }

  /* ─── FEATURES ─── */
  .features-section {
    padding: 0 24px 120px;
    max-width: 960px;
    margin: 0 auto;
  }

  .features-header { margin-bottom: 0; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .feature-item {
    background: var(--surface);
    padding: 36px 32px;
    transition: background .2s;
  }

  .feature-item:hover { background: #161616; }

  .feature-icon {
    width: 36px; height: 36px;
    border-radius: 6px;
    border: 1px solid var(--border2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: var(--accent);
    transition: border-color .2s;
  }

  .feature-item:hover .feature-icon { border-color: var(--accent); }

  .feature-title {
    font-size: 15px;
    font-weight: 500;
    margin-bottom: 8px;
    letter-spacing: -.01em;
  }

  .feature-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  .feature-desc code {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 12px;
    color: var(--accent);
  }

  /* ─── STACK ─── */
  .stack-section {
    padding: 0 24px 120px;
    max-width: 960px;
    margin: 0 auto;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .stack-item {
    background: var(--surface);
    padding: 28px 32px;
  }

  .stack-label {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 11px;
    color: var(--muted2);
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .stack-value {
    font-family: var(--mono);
    font-variation-settings: 'MONO' 1, 'CASL' 0;
    font-size: 14px;
    color: var(--text);
    line-height: 2;
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .tool-hero {
      padding: 80px 16px 60px;
      min-height: auto;
    }

    .tool-hero h1 { margin-bottom: 24px; }

    .tool-tagline { margin: 0 auto 40px; }

    .tool-cta { gap: 10px; }

    .stat-row {
      grid-template-columns: 1fr;
      width: calc(100% - 32px);
      margin-bottom: 64px;
    }

    .stat-item { padding: 24px 20px; }

    .stat-value { font-size: 32px; }

    .about-section {
      padding: 0 16px 64px;
      grid-template-columns: 1fr;
      gap: 0;
    }

    .about-block { padding: 24px 0; }

    .features-section {
      padding: 0 16px 64px;
    }

    .features-grid { grid-template-columns: 1fr; }

    .feature-item { padding: 24px 20px; }

    .stack-section {
      padding: 0 16px 64px;
    }

    .stack-grid { grid-template-columns: 1fr; }

    .stack-item { padding: 20px; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = el.style.getPropertyValue('--reveal-delay') || '0s';
          setTimeout(() => {
            el.classList.add('visible');
          }, parseFloat(delay) * 1000);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
