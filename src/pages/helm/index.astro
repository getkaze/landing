---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import InstallBlock from '../../components/InstallBlock.astro';
---

<Base
  title="Helm | AI agent orchestration for backend development."
  description="Structured AI agent pipeline for backend projects. 12 specialized agents, quality gates, and full session continuity."
>
  <Nav activePage="helm" />

  <!-- HERO -->
  <section class="hero">
    <span class="eyebrow">v0.1 · alpha · MIT</span>
    <h1>Helm</h1>
    <p class="lead">AI agent orchestration for backend development.</p>
    <div class="install-wrap">
      <InstallBlock
        command="curl -fsSL https://getkaze.dev/helm/install.sh | bash"
        thenCommand="helm init"
      />
    </div>
    <div class="hero-ctas">
      <a href="https://github.com/getkaze/helm" class="btn-primary">View on GitHub</a>
      <a href="/helm/docs/en" class="btn-secondary">Docs</a>
    </div>
  </section>

  <!-- TERMINAL -->
  <section class="terminal-section">
    <div class="helm-terminal" data-helm-page-anim>
      <div class="helm-terminal-bar">
        <span class="helm-dot"></span><span class="helm-dot"></span><span class="helm-dot"></span>
        <span class="helm-terminal-title">helm status</span>
      </div>
      <div class="helm-terminal-body">
        <div class="ht-line" data-delay="0"><span class="ht-prompt">$</span> <span class="ht-cmd">helm status</span></div>
        <div class="ht-line ht-blank" data-delay="600"></div>
        <div class="ht-line" data-delay="800">  <span class="ht-heading">Helm v0.1</span></div>
        <div class="ht-line ht-blank" data-delay="1000"></div>
        <div class="ht-line" data-delay="1100">  <span class="ht-label">Project:</span>  <span class="ht-value">my-api</span></div>
        <div class="ht-line" data-delay="1200">  <span class="ht-label">Type:</span>     <span class="ht-value">brownfield</span></div>
        <div class="ht-line" data-delay="1300">  <span class="ht-label">Phase:</span>    <span class="ht-value">build</span></div>
        <div class="ht-line" data-delay="1400">  <span class="ht-label">Profile:</span>  <span class="ht-value">guided</span></div>
        <div class="ht-line" data-delay="1500">  <span class="ht-label">Language:</span> <span class="ht-value">en-US</span></div>
        <div class="ht-line ht-blank" data-delay="1700"></div>
        <div class="ht-line" data-delay="1900">  <span class="ht-label">Pipeline:</span></div>
        <div class="ht-line" data-delay="2100">    <span class="ht-done">[done]</span>  <span class="ht-agent">survey</span>       <span class="ht-score">92%</span></div>
        <div class="ht-line" data-delay="2300">    <span class="ht-done">[done]</span>  <span class="ht-agent">research</span>     <span class="ht-score">95%</span></div>
        <div class="ht-line" data-delay="2500">    <span class="ht-done">[done]</span>  <span class="ht-agent">planning</span>     <span class="ht-score">92%</span></div>
        <div class="ht-line" data-delay="2700">    <span class="ht-done">[done]</span>  <span class="ht-agent">architect</span>    <span class="ht-score">94%</span></div>
        <div class="ht-line" data-delay="2900">    <span class="ht-done">[done]</span>  <span class="ht-agent">roadmap</span>      <span class="ht-score">94%</span></div>
        <div class="ht-line" data-delay="3100">    <span class="ht-done">[done]</span>  <span class="ht-agent">breakdown</span>    <span class="ht-score">92%</span></div>
        <div class="ht-line" data-delay="3300">    <span class="ht-done">[done]</span>  <span class="ht-agent">review</span>       <span class="ht-score-high">100%</span></div>
        <div class="ht-line" data-delay="3600">    <span class="ht-active">[>>  ]</span>  <span class="ht-agent-active">build</span>        <span class="ht-desc-active">in progress<span class="ht-blink">_</span></span></div>
        <div class="ht-line" data-delay="3800">    <span class="ht-pending">[    ]</span>  <span class="ht-agent-pending">verify</span>       <span class="ht-pending">pending</span></div>
        <div class="ht-line" data-delay="4000">    <span class="ht-pending">[    ]</span>  <span class="ht-agent-pending">ship</span>         <span class="ht-pending">pending</span></div>
        <div class="ht-line ht-blank" data-delay="4300"></div>
        <div class="ht-line" data-delay="4500">  <span class="ht-label">Deviations:</span> <span class="ht-value">0</span></div>
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section>
    <div class="two-col">
      <div>
        <h2>Structured, not free-form</h2>
        <p>AI-assisted development works best when structured. Instead of free-form prompting, Helm guides your project through a pipeline of specialized agents, each with clear acceptance criteria and quality gates.</p>
      </div>
      <div>
        <h2>The wheel that steers</h2>
        <p>Named after the helm, the wheel that steers a ship. It translates the captain's intent into the rudder's movement. Helm does the same for your development pipeline.</p>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section>
    <div class="features-row">
      <div class="feature">
        <h3>12 agents, one pipeline</h3>
        <p>Five phases (Discover, Plan, Build, Quality, Deploy), each driven by specialized agents that know their mission from the handoff.</p>
      </div>
      <div class="feature">
        <h3>Quality gates</h3>
        <p>Two QA checkpoints at 95% threshold. Review validates planning, Verify validates implementation. Every task traces to a requirement.</p>
      </div>
      <div class="feature">
        <h3>Session continuity</h3>
        <p>Checkpoint state, close Claude Code, resume later. All progress survives across sessions. Decisions are never lost.</p>
      </div>
      <div class="feature">
        <h3>Markdown-driven</h3>
        <p>Agent definitions are plain markdown files. No proprietary runtime. Fork, edit, and extend the pipeline to match your workflow.</p>
      </div>
    </div>
  </section>

  <!-- PIPELINE -->
  <section>
    <h2>Pipeline</h2>
    <p class="section-lead">Every project flows through the same structured phases.</p>
    <div class="pipeline">
      <div class="pipeline-phase">
        <span class="pipeline-label">Discover</span>
        <div class="pipeline-agents">
          <span>Scout</span>
          <span>Research</span>
        </div>
      </div>
      <div class="pipeline-arrow">&rarr;</div>
      <div class="pipeline-phase">
        <span class="pipeline-label">Plan</span>
        <div class="pipeline-agents">
          <span>Planning</span>
          <span>Architect</span>
          <span>Roadmap</span>
          <span>Breakdown</span>
        </div>
      </div>
      <div class="pipeline-arrow">&rarr;</div>
      <div class="pipeline-phase">
        <span class="pipeline-label">Quality</span>
        <div class="pipeline-agents">
          <span>Review</span>
        </div>
      </div>
      <div class="pipeline-arrow">&rarr;</div>
      <div class="pipeline-phase">
        <span class="pipeline-label">Build</span>
        <div class="pipeline-agents">
          <span>Build</span>
        </div>
      </div>
      <div class="pipeline-arrow">&rarr;</div>
      <div class="pipeline-phase">
        <span class="pipeline-label">Quality</span>
        <div class="pipeline-agents">
          <span>Verify</span>
        </div>
      </div>
      <div class="pipeline-arrow">&rarr;</div>
      <div class="pipeline-phase">
        <span class="pipeline-label">Deploy</span>
        <div class="pipeline-agents">
          <span>Ship</span>
        </div>
      </div>
    </div>
  </section>

  <!-- MODES -->
  <section>
    <div class="features-row">
      <div class="feature">
        <h3>Explore</h3>
        <p>Read-only. Agents analyze and suggest but perform no writes. Safe for initial assessment.</p>
      </div>
      <div class="feature">
        <h3>Guided</h3>
        <p>Default. Agents propose actions, you confirm before writes. Full control with AI leverage.</p>
      </div>
      <div class="feature">
        <h3>Autonomous</h3>
        <p>Agents execute without confirmation when gate scores pass 95%. Reverts to guided when quality drops.</p>
      </div>
      <div class="feature">
        <h3>10 governance rules</h3>
        <p>Boundaries, quality bars, handoff protocols, security. Agents can't skip steps or inflate scores.</p>
      </div>
    </div>
  </section>

  <Footer product="helm" />
</Base>

<style>
  .hero {
    text-align: center;
    padding: calc(72px + var(--space-3xl)) var(--space-lg) var(--space-2xl);
    width: var(--shell-narrow);
    margin: 0 auto;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .hero h1 {
    font-size: var(--text-display);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-top: var(--space-lg);
  }

  .lead {
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    margin-top: var(--space-md);
    line-height: var(--leading-relaxed);
    letter-spacing: -0.015em;
  }

  .install-wrap {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .section-lead {
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2xl);
    letter-spacing: -0.015em;
  }

  /* Terminal */
  .terminal-section {
    padding-top: 0;
  }

  .helm-terminal {
    width: 100%;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: #0f1117;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06), 0 24px 60px rgba(15, 23, 42, 0.08);
    border: 1px solid #1e2028;
  }

  .helm-terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    background: #161822;
    border-bottom: 1px solid #1e2028;
  }

  .helm-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #2a2d3a;
  }

  .helm-terminal-title {
    margin-left: auto;
    margin-right: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    color: #555;
    letter-spacing: 0.04em;
  }

  .helm-terminal-body {
    padding: 20px 24px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
    color: #6b7280;
  }

  :global(.ht-line) { opacity: 0; transform: translateY(4px); white-space: pre; min-height: 1.7em; }
  :global(.ht-line.ht-visible) { opacity: 1; transform: translateY(0); transition: opacity 0.3s ease, transform 0.3s ease; }
  :global(.ht-line.ht-blank) { min-height: 0.8em; }
  :global(.ht-prompt) { color: #22c55e; }
  :global(.ht-cmd) { color: #e5e7eb; }
  :global(.ht-heading) { color: #e5e7eb; font-weight: 700; }
  :global(.ht-label) { color: #6b7280; }
  :global(.ht-value) { color: #d1d5db; }
  :global(.ht-done) { color: #22c55e; }
  :global(.ht-active) { color: #f59e0b; }
  :global(.ht-pending) { color: #374151; }
  :global(.ht-agent) { color: #9ca3af; }
  :global(.ht-agent-active) { color: #e5e7eb; font-weight: 600; }
  :global(.ht-agent-pending) { color: #374151; }
  :global(.ht-score) { color: #22c55e; }
  :global(.ht-score-high) { color: #4ade80; font-weight: 600; }
  :global(.ht-desc) { color: #4b5563; }
  :global(.ht-desc-active) { color: #f59e0b; }
  :global(.ht-desc-pending) { color: #374151; }
  :global(.ht-blink) { animation: blink 1s step-end infinite; color: #f59e0b; }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* Two col */
  .two-col {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2xl);
  }

  .two-col h2 {
    font-size: var(--text-h2);
    font-weight: 800;
    margin-bottom: var(--space-sm);
  }

  .two-col p {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  /* Features */
  .features-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .feature h3 {
    font-size: var(--text-body);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .feature p {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  /* Pipeline */
  .pipeline {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    overflow-x: auto;
    padding: var(--space-sm) 0;
  }

  .pipeline-phase {
    flex: 1;
    min-width: 110px;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-align: center;
  }

  .pipeline-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .pipeline-agents {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .pipeline-agents span {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text);
  }

  .pipeline-arrow {
    display: flex;
    align-items: center;
    color: var(--color-text-muted);
    font-size: var(--text-h2);
    padding-top: var(--space-2xl);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .two-col {
      grid-template-columns: 1fr;
    }

    .features-row {
      grid-template-columns: repeat(2, 1fr);
    }

    .pipeline {
      flex-direction: column;
      align-items: stretch;
    }

    .pipeline-arrow {
      padding-top: 0;
      justify-content: center;
      transform: rotate(90deg);
    }

    .hero-ctas {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

<script>
  // Animate terminal on scroll into view
  const terminal = document.querySelector('[data-helm-page-anim]');
  if (terminal) {
    const lines = terminal.querySelectorAll('.ht-line');
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          lines.forEach(line => {
            const delay = parseInt((line as HTMLElement).dataset.delay || '0', 10);
            setTimeout(() => line.classList.add('ht-visible'), delay);
          });
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    obs.observe(terminal);
  }
</script>
